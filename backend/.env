# ─── Server ─────────────────────────────────────────
PORT=4000

# ─── MongoDB ────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/smart_cradle

# ─── MQTT Broker ────────────────────────────────────
MQTT_BROKER=mqtt://broker.hivemq.com:1883
MQTT_TOPIC_SENSOR=smartcradle/sensors
MQTT_TOPIC_COMMAND=smartcradle/command

# ─── Email Configuration for Alerts to Mother ─────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_RECEIVER=mother_email_or_phone@gmail.com
